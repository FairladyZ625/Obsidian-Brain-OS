{"$schema": "http://json-schema.org/draft-07/schema#", "$id": "friction-report.schema.json", "title": "FrictionReport", "description": "An aggregated friction report for a review period.", "type": "object", "required": ["report_id", "period_start", "period_end", "signals", "buckets", "findings", "recommended_actions"], "properties": {"report_id": {"type": "string", "description": "Unique report identifier, e.g. FR-2026-W16"}, "period_start": {"type": "string", "format": "date"}, "period_end": {"type": "string", "format": "date"}, "agent": {"type": "string", "description": "Agent that produced this report"}, "status": {"type": "string", "enum": ["draft", "reviewed", "final"], "default": "draft"}, "signals": {"type": "array", "items": {"$ref": "#/$defs/FrictionSignalSummary"}, "description": "All friction signals in this period"}, "buckets": {"type": "object", "additionalProperties": {"type": "object", "properties": {"name": {"type": "string"}, "count": {"type": "integer"}, "signal_ids": {"type": "array", "items": {"type": "string"}}, "pattern_description": {"type": "string"}}}, "description": "Signals grouped by bucket"}, "findings": {"type": "array", "items": {"$ref": "#/$defs/Finding"}}, "recommended_actions": {"type": "array", "items": {"$ref": "#/$defs/WritebackAction"}}, "noise": {"type": "array", "items": {"type": "object", "properties": {"summary": {"type": "string"}, "skip_reason": {"type": "string"}}}}, "next_review_date": {"type": "string", "format": "date"}}, "$defs": {"FrictionSignalSummary": {"type": "object", "properties": {"id": {"type": "string"}, "summary": {"type": "string"}, "bucket": {"type": "string"}, "severity": {"type": "string"}, "recurring": {"type": "boolean"}}, "required": ["id", "summary", "bucket"]}, "Finding": {"type": "object", "properties": {"bucket": {"type": "string"}, "root_cause": {"type": "string"}, "broken_layer": {"type": "string"}, "is_structural": {"type": "boolean"}}, "required": ["bucket", "root_cause", "broken_layer"]}, "WritebackAction": {"type": "object", "properties": {"finding_ref": {"type": "string"}, "target_layer": {"type": "string", "enum": ["prompt", "agents", "reference", "workflow", "docs_onboarding", "boundary", "none"]}, "proposed_action": {"type": "string"}, "priority": {"type": "string", "enum": ["critical", "high", "medium", "low"]}}, "required": ["target_layer", "proposed_action", "priority"]}}}