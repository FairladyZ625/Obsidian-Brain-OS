{"$schema": "http://json-schema.org/draft-07/schema#", "$id": "friction-event.schema.json", "title": "FrictionEvent", "description": "A single friction signal captured from system operation.", "type": "object", "required": ["id", "timestamp", "source", "summary", "bucket"], "properties": {"id": {"type": "string", "pattern": "^F-\\d{4}$", "description": "Unique signal identifier, e.g. F-0001"}, "timestamp": {"type": "string", "format": "date-time", "description": "When the friction was observed (ISO 8601)"}, "source": {"type": "string", "enum": ["user_correction", "failed_output", "workflow_miss", "planning_mistake", "review_finding", "observer_alert"], "description": "Where this signal came from"}, "summary": {"type": "string", "maxLength": 200, "description": "One-line human-readable description"}, "bucket": {"type": "string", "enum": ["prompt_ambiguity", "reference_miss", "agents_visibility_gap", "workflow_blind_spot", "naming_structure_confusion", "boundary_privacy_issue", "onboarding_gap", "structural_drift"], "description": "Standard classification bucket"}, "severity": {"type": "string", "enum": ["low", "medium", "high", "critical"], "default": "medium"}, "recurring": {"type": "boolean", "description": "Whether this same pattern has been seen before"}, "recurrence_count": {"type": "integer", "minimum": 1, "description": "How many times this pattern has appeared (including this one)"}, "suggested_writeback_layer": {"type": "string", "enum": ["prompt", "agents", "reference", "workflow", "docs_onboarding", "boundary", "none"], "description": "Recommended target layer for governance fix"}, "context_url": {"type": "string", "format": "uri", "description": "Optional link to relevant issue/PR/discussion"}}}